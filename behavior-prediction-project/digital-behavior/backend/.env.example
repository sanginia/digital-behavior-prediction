# Database Configuration
# For local development with PostgreSQL:
DATABASE_URL=postgresql://user:password@localhost:5432/digital_behavior_prediction

# For production with PostgreSQL:
# DATABASE_URL=postgresql://user:password@your-db-host:5432/digital_behavior_prediction

# For local development with SQLite (easier setup):
# DATABASE_URL=sqlite:///./digital_behavior.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Origins (comma-separated, no chrome-extension needed as it's auto-added)
# For local development:
ALLOWED_ORIGINS=http://localhost:3000
# For production (replace with your actual domain):
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Session Configuration
SESSION_TIMEOUT_MINUTES=30

# Logging
LOG_LEVEL=INFO
