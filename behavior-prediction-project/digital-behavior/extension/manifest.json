{
  "manifest_version": 3,
  "name": "Digital Behavior Prediction",
  "version": "0.1.0",
  "description": "Tracks browser behavior patterns to predict task abandonment and provide interventions",
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
